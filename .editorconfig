################################################################################
# InfraLab
################################################################################

root = true

################################################################################
# Default
################################################################################

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

################################################################################
# Python
################################################################################

[*.py]
indent_size = 4

################################################################################
# Terraform
################################################################################

[*.tf]
indent_size = 2

[*.tfvars]
indent_size = 2

################################################################################
# YAML
################################################################################

[*.{yml,yaml}]
indent_size = 2

################################################################################
# JSON
################################################################################

[*.json]
indent_size = 2

################################################################################
# Markdown
################################################################################

[*.md]
trim_trailing_whitespace = false

################################################################################
# Shell
################################################################################

[*.sh]
indent_size = 2

################################################################################
# Docker
################################################################################

Dockerfile
indent_size = 2

################################################################################
# Makefile
################################################################################

[Makefile]
indent_style = tab
