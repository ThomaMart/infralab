################################################################################
# InfraLab
# .gitignore
################################################################################

################################################################################
# Terraform
################################################################################

**/.terraform/
*.tfstate
*.tfstate.*
crash.log
crash.*.log

override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Local plans
*.tfplan
plan.out

# Local variables
**/terraform.tfvars
**/*.auto.tfvars

################################################################################
# Python
################################################################################

__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
ENV/

# Packaging
build/
dist/
*.egg-info/
.eggs/

# Cache
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.nox/
.cache/

# Coverage
.coverage
.coverage.*
coverage.xml
htmlcov/

################################################################################
# FastAPI
################################################################################

instance/

################################################################################
# Docker
################################################################################

**/.env

# Keep examples
!**/.env.example

################################################################################
# Ansible
################################################################################

*.retry

################################################################################
# Local configuration
################################################################################

env/env.sh
scripts/template.env

################################################################################
# Secrets
################################################################################

*.pem
*.key
*.crt
*.csr
*.p12
*.pfx

################################################################################
# Logs
################################################################################

*.log
logs/
*.pid

################################################################################
# Editors
################################################################################

.vscode/
.idea/

################################################################################
# Vim
################################################################################

*.swp
*.swo
*~

################################################################################
# Operating systems
################################################################################

.DS_Store
Thumbs.db

################################################################################
# Misc
################################################################################

tmp/
temp/

################################################################################
# Terraform lock file
# This file SHOULD be versioned.
################################################################################

!.terraform.lock.hcl
